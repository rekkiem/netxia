# ═══════════════════════════════════════════════════════════════════
# NETXIA — .htaccess v1.2
# Fix: solo bloquea carpetas y config.php, NO los endpoints AJAX
# ═══════════════════════════════════════════════════════════════════

ErrorDocument 404 /404.html
ErrorDocument 403 /403.html
ErrorDocument 500 /500.html

Options -Indexes
Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  # ─── PRODUCCIÓN (50webs): déjalo en /
  # ─── LOCAL XAMPP en /netxia/: cambia a RewriteBase /netxia/
  RewriteBase /

  # Forzar HTTPS (solo con SSL activo, descomenta en producción)
  # RewriteCond %{HTTPS} off
  # RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # Bloquear carpetas de datos — NO los archivos PHP individuales
  RewriteRule ^data(/.*)?$           - [F,L]
  RewriteRule ^logs(/.*)?$           - [F,L]
  RewriteRule ^uploads/cv(/.*)?$     - [F,L]
  RewriteRule ^php/phpmailer(/.*)?$  - [F,L]

  # Bloquear user-agents maliciosos
  RewriteCond %{HTTP_USER_AGENT} (nikto|sqlmap|nessus|openvas|masscan|nmap|zap|burp) [NC]
  RewriteRule .* - [F,L]
</IfModule>

# ─── Bloquear SOLO config.php (los endpoints AJAX son accesibles) ────
<Files "config.php">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</Files>

# ─── Archivos sensibles y backups ────────────────────────────────────
<FilesMatch "\.(bak|swp|orig|tmp|sql|sqlite|env)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>
<Files ".ht*">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</Files>

# ─── Cabeceras de seguridad ───────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.anthropic.com; frame-ancestors 'none';"
  Header unset X-Powered-By
</IfModule>

# ─── Compresión ───────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

# ─── Caché de navegador ───────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp         "access plus 6 months"
  ExpiresByType image/jpeg         "access plus 6 months"
  ExpiresByType image/png          "access plus 6 months"
  ExpiresByType font/woff2         "access plus 1 year"
  ExpiresByType text/css           "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType text/html          "access plus 0 seconds"
</IfModule>

# ─── PHP (50webs compartido) ─────────────────────────────────────────
<IfModule mod_php.c>
  php_value upload_max_filesize 2M
  php_value post_max_size 4M
  php_value max_execution_time 60
  php_value memory_limit 128M
  php_flag display_errors off
  php_flag log_errors on
</IfModule>

AddDefaultCharset UTF-8
