# ═══════════════════════════════════════════════════════════════════
# NETXIA — .htaccess principal (ENTORNO DE PRODUCCIÓN - 50WEBS)
# ═══════════════════════════════════════════════════════════════════

# ── Errores personalizados (Apuntando a la raíz del dominio) ──────────
ErrorDocument 404 /404.html
ErrorDocument 403 /403.html
ErrorDocument 500 /500.html

# ── Reescritura de URLs (mod_rewrite) ─────────────────────────────────
Options -Indexes
Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Base de reescritura en la raíz real del hosting
  RewriteBase /

  # Forzar HTTPS (Descomenta quitando el '#' cuando instales tu certificado SSL en 50webs)
  # RewriteCond %{HTTPS} off
  # RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # Forzar sin www → con www (Opcional, según prefieras tu dominio)
  # RewriteCond %{HTTP_HOST} !^www\. [NC]
  # RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [R=301,L]

  # Permitir el acceso exclusivo al archivo blog.json
    RewriteRule ^data/blog\.json$ - [L]

  # Bloquear el acceso al resto de archivos dentro de directorios sensibles (como data/sessions)
  RewriteRule ^(data|logs|uploads/cv|php/phpmailer)(/|$) - [F,L]

  # Bloquear acceso directo a archivos PHP de configuración (dejando libres los submit_)
  RewriteRule ^php/(config|csrf|chatbot)$ - [F,L]

  # Enrutamiento de URLs amigables para el Blog
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^blog$ blog.html [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^blog/([^/]+)$ entrada.html?slug=$1 [L]
</IfModule>

# ── Seguridad Extrema (Cabeceras HTTP) ────────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: https:; connect-src 'self' https://api.anthropic.com; frame-src 'none'; object-src 'none';"
</IfModule>

# ── Optimización: Caché de Navegador (Módulos de expiración) ──────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  # Imágenes y multimedia
  ExpiresByType image/webp        "access plus 6 months"
  ExpiresByType image/avif        "access plus 6 months"
  ExpiresByType image/jpeg        "access plus 6 months"
  ExpiresByType image/png         "access plus 6 months"
  ExpiresByType image/svg+xml     "access plus 1 month"
  ExpiresByType image/x-icon      "access plus 1 year"
  # Fuentes
  ExpiresByType font/woff2        "access plus 1 year"
  ExpiresByType font/woff         "access plus 1 year"
  # CSS y JS
  ExpiresByType text/css          "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  # HTML y PHP (Siempre fresco para procesar formularios)
  ExpiresByType text/html         "access plus 0 seconds"
</IfModule>

# ── Performance: Control de Caché Avanzado ────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|webp|avif|jpg|jpeg|png|gif|svg|woff2|woff)$">
    Header set Cache-Control "public, max-age=604800, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Bloquear User-Agents maliciosos (Seguridad básica) ────────────────
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_USER_AGENT} (nikto|sqlmap|nessus|openvas|masscan|nmap|zap|burp) [NC]
  RewriteRule .* - [F,L]
</IfModule>