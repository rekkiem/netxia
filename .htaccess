# ═══════════════════════════════════════════════════════════════════
# NETXIA — .htaccess principal (Apache compatible con 50webs)
# ═══════════════════════════════════════════════════════════════════

# ── Errores personalizados ────────────────────────────────────────────
ErrorDocument 404 /404.html
ErrorDocument 403 /403.html
ErrorDocument 500 /500.html

# ── Reescritura de URLs (mod_rewrite) ─────────────────────────────────
Options -Indexes
Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Forzar HTTPS (actívalo solo cuando tengas SSL en 50webs)
  # RewriteCond %{HTTPS} off
  # RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # Forzar sin www → con www (ajusta según tu preferencia)
  # RewriteCond %{HTTP_HOST} !^www\. [NC]
  # RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [R=301,L]

  # Bloquear acceso a directorios sensibles
  RewriteRule ^(data|logs|uploads/cv|php/phpmailer)(/|$) - [F,L]

  # Bloquear acceso directo a archivos PHP internos
  RewriteRule ^php/(config|csrf|chatbot|submit_) - [F,L]

  # Redirigir .html extensiones limpias (opcional, desactivado por defecto)
  # RewriteCond %{REQUEST_FILENAME} !-d
  # RewriteCond %{REQUEST_FILENAME} !-f
  # RewriteRule ^([^.]+)$ $1.html [NC,L]
</IfModule>

# ── Cabeceras de Seguridad ─────────────────────────────────────────────
<IfModule mod_headers.c>
  # Clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"
  # MIME sniffing
  Header always set X-Content-Type-Options "nosniff"
  # XSS Filter (navegadores legacy)
  Header always set X-XSS-Protection "1; mode=block"
  # Referrer
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Permissions Policy
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # HSTS (solo con SSL activo)
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Content Security Policy ajustada para Netxia
  Header always set Content-Security-Policy "\
    default-src 'self'; \
    script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; \
    style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; \
    font-src 'self' https://fonts.gstatic.com; \
    img-src 'self' data: https:; \
    connect-src 'self' https://api.anthropic.com; \
    frame-ancestors 'none';"

  # Eliminar cabeceras que revelan tecnología del servidor
  Header unset X-Powered-By
  Header always unset Server
</IfModule>

# ── Protección de archivos sensibles ──────────────────────────────────
<FilesMatch "^(config\.php|\.env|composer\.json|package\.json|README\.md|\.gitignore|\.travis\.yml)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# Bloquear archivos de backup y editores
<FilesMatch "\.(bak|swp|swo|orig|tmp|log|sql|db|sqlite)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

# Bloquear .htaccess y .htpasswd
<Files ".ht*">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</Files>

# ── Performance: Compresión GZIP ─────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/x-font-ttf font/opentype image/svg+xml
</IfModule>

# ── Performance: Cache de navegador ──────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  # Imágenes
  ExpiresByType image/webp        "access plus 6 months"
  ExpiresByType image/avif        "access plus 6 months"
  ExpiresByType image/jpeg        "access plus 6 months"
  ExpiresByType image/png         "access plus 6 months"
  ExpiresByType image/svg+xml     "access plus 1 month"
  ExpiresByType image/x-icon      "access plus 1 year"
  # Fuentes
  ExpiresByType font/woff2        "access plus 1 year"
  ExpiresByType font/woff         "access plus 1 year"
  # CSS y JS (versionar en producción con ?v=X.X)
  ExpiresByType text/css          "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  # HTML y PHP: sin caché (siempre fresco)
  ExpiresByType text/html         "access plus 0 seconds"
</IfModule>

# ── Performance: ETags ───────────────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|webp|avif|jpg|jpeg|png|gif|svg|woff2|woff)$">
    Header set Cache-Control "public, max-age=604800, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Bloquear User-Agents maliciosos ─────────────────────────────────
<IfModule mod_rewrite.c>
  # Bloquear acceso a directorios sensibles
    RewriteRule ^(data|logs|uploads/cv|php/phpmailer)(/|$) - [F,L]

    # SOLUCIÓN: Bloquear solo archivos internos de configuración, permitiendo los "submit_"
    RewriteRule ^php/(config|csrf|chatbot)$ - [F,L]
</IfModule>

# ── Límite de tamaño de subida (máx 2 MB para 50webs) ────────────────
<IfModule mod_php.c>
  php_value upload_max_filesize 2M
  php_value post_max_size 4M
  php_value max_execution_time 60
  php_value memory_limit 128M
  php_flag display_errors off
  php_flag log_errors on
</IfModule>

# Charset por defecto
AddDefaultCharset UTF-8
